# ETΞRNET — Environment Variables
# Copy this file to .env and fill in your values

# IBM Quantum QRNG API Key (optional — enables real quantum random numbers)
# Get yours at: https://quantum-computing.ibm.com/
VITE_IBM_QRNG_API_KEY=

# Mercado Pago Access Token (optional — for payment gateway)
VITE_MP_ACCESS_TOKEN=

# NOSTR Relays (comma-separated, optional override)
VITE_NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net
