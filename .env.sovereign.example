# ET-RNET — Variáveis de ambiente da stack soberana
# Copie para .env.sovereign e preencha antes de subir o docker compose

# ── Rede Bitcoin ──────────────────────────────────────────────────────────────
BITCOIN_NETWORK=regtest          # regtest | testnet | mainnet
BITCOIN_RPC_USER=void
BITCOIN_RPC_PASS=voidpassword_troca_isso
BITCOIN_RPC_PORT=18443           # 8332=mainnet, 18332=testnet, 18443=regtest

# ── LND ───────────────────────────────────────────────────────────────────────
LND_ALIAS=VOID-NODE-01
# REST API exposta na porta 8180 (8080 pode estar ocupada pelo Hyperspace ou outro processo)
# LND_REST_URL=https://127.0.0.1:8180  ← usar esta se acessar de fora do Docker
# Admin macaroon em hex — obtido após `lncli create`:
#   docker exec lnd cat /root/.lnd/data/chain/bitcoin/regtest/admin.macaroon | xxd -p -c 256
LND_MACAROON_HEX=

# ── NWC (Nostr Wallet Connect) ────────────────────────────────────────────────
# URI gerada pelo RTL (Settings > NWC) após configurar um budget
NWC_SECRET=nostr+walletconnect://...

# ── ETRNETAnchor (Solidity) ───────────────────────────────────────────────────
PRIVATE_KEY=                     # hex sem 0x — apenas para deploy
SEPOLIA_RPC_URL=https://rpc.sepolia.org
DAO_MULTISIG=                    # endereço Safe multisig (obrigatório em mainnet)
ETHERSCAN_API_KEY=
ETRNET_ANCHOR_ADDRESS=           # preenchido após deploy
